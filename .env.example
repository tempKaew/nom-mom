# Supabase – get these from your project: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Use Service Role key in API routes so reads/writes bypass RLS (recommended; keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE LIFF – from LINE Developers Console (LIFF tab)
NEXT_PUBLIC_LIFF_ID=your-liff-id
# Channel ID of the channel that owns the LIFF app (for server-side ID token verification)
LIFF_CHANNEL_ID=your-channel-id
